{
  "name": "laravel-swaggenerai",
  "displayName": "Laravel SwaggenerAI (L5 Swagger Generator)",
  "description": "Generate Swagger documentation from Laravel files using AI.",
  "version": "1.0.1",
  "publisher": "PESEDevs",
  "icon": "images/swag.png",
  "galleryBanner": {
    "color": "#FF2D20",
    "theme": "dark"
  },
  "keywords": [
    "laravel",
    "swagger",
    "openapi",
    "documentation",
    "ai"
  ],
  "badges": [
    {
      "url": "https://img.shields.io/visual-studio-marketplace/v/PESEDevsaravel-swaggenerai.svg",
      "href": "https://marketplace.visualstudio.com/items?itemName=PESEDevs.laravel-swaggenerai",
      "description": "Extension Version"
    },
    {
      "url": "https://img.shields.io/visual-studio-marketplace/i/PESEDevs.laravel-swaggenerai.svg",
      "href": "https://marketplace.visualstudio.com/items?itemName=PESEDevs.laravel-swaggenerai",
      "description": "Install Count"
    },
    {
      "url": "https://img.shields.io/github/license/PESEDevs/laravel-swaggenerai.svg",
      "href": "https://github.com/petersonsenadevs/laravel-swaggenerai/blob/main/LICENSE",
      "description": "License"
    }
  ],
  "engines": {
    "vscode": "^1.96.0"
  },
  "categories": [
    "AI",
    "Other",
    "Snippets",
    "Programming Languages",
    "Formatters"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "laravel-swaggenerai.generateDocs",
        "title": "Generate Swagger Documentation",
        "category": "Laravel SwaggenerAI"
      },
      {
        "command": "laravel-swaggenerai.editApiKey",
        "title": "Update API Key",
        "category": "Laravel SwaggenerAI"
      },
      {
        "command": "laravel-swaggenerai.selectProvider",
        "title": "Select AI Provider",
        "category": "Laravel SwaggenerAI"
      },
      {
        "command": "laravel-swaggenerai.ollamaCommands",
        "title": "Ollama Commands",
        "category": "Laravel SwaggenerAI"
      }
    ],
    "configuration": {
      "title": "Laravel Swagger AI Generator",
      "properties": {
        "laravelSwaggerAi.selectedModel": {
          "type": "string",
          "enum": [
            "gemini",
            "openai",
            "anthropic",
            "ollama"
          ],
          "default": "gemini",
          "description": "Selected AI model"
        },
        "laravelSwaggerAi.geminiApiKey": {
          "type": "string",
          "default": "",
          "description": "Gemini API Key"
        },
        "laravelSwaggerAi.openaiApiKey": {
          "type": "string",
          "default": "",
          "description": "OpenAI API Key"
        },
        "laravelSwaggerAi.anthropicApiKey": {
          "type": "string",
          "default": "",
          "description": "Anthropic API Key"
        },
        "laravelSwaggerAi.ollamaModel": {
          "type": "string",
          "default": "llama2",
          "description": "Selected Ollama model name"
        }
      }
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "laravelSwaggeneraiSidebar",
          "title": "Laravel Swagger",
          "icon": "images/swag.png"
        }
      ]
    },
    "views": {
      "laravelSwaggeneraiSidebar": [
        {
          "id": "laravelSwaggenerai.folderSelectionView",
          "name": "Escaneo Laravel"
        }
      ]
    }
  },
  "author": {
    "name": "Peterson Sena",
    "url": "https://github.com/petersonsenadevs",
    "website": "https://petersonsena.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/petersonsenadevs/laravel-swaggenerai"
  },
  "license": "MIT",
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.17.2",
    "@google/generative-ai": "^0.24.1",
    "glob": "^8.1.0",
    "minimatch": "^3.1.2",
    "openai": "^4.103.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "@types/glob": "^8.1.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "20.x",
    "@types/vscode": "^1.96.0",
    "@typescript-eslint/eslint-plugin": "^8.31.1",
    "@typescript-eslint/parser": "^8.31.1",
    "@vscode/test-cli": "^0.0.10",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^9.25.1",
    "typescript": "^5.8.3"
  }
}