{
  "name": "laravel-swagger-ai-generator",
  "displayName": "Laravel Swagger AI Generator",
  "description": "Generate Swagger documentation from Laravel files using Gemini AI",
  "version": "1.0.0",
  "engines": {
    "vscode": "^1.100.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "laravel-swagger-ai-generator.generateDocs",
        "title": "Laravel Swagger: Generar documentación",
        "category": "Extension"
      },
      {
        "command": "laravel-swagger-ai-generator.editApiKey",
        "title": "Laravel Swagger: Editar API Key de los proveedores",
        "category": "Extension"
      },
     
      {
    "command": "laravel-swagger-ai-generator.selectProvider",
    "title": "Laravel Swagger: Seleccionar Proveedor de IA",
    "category": "Extension"
  }
    ],
   "configuration": {
            "title": "Laravel Swagger AI Generator",
            "properties": {
                "laravelSwaggerAi.selectedModel": {
                    "type": "string",
                    "enum": ["gemini", "openai", "anthropic"],
                    "default": "gemini",
                    "description": "Proveedor de IA seleccionado"
                },
                "laravelSwaggerAi.geminiApiKey": {
                    "type": "string",
                    "default": "",
                    "description": "API Key para Google Gemini"
                },
                "laravelSwaggerAi.openaiApiKey": {
                    "type": "string",
                    "default": "",
                    "description": "API Key para OpenAI"
                },
                "laravelSwaggerAi.anthropicApiKey": {
                    "type": "string",
                    "default": "",
                    "description": "API Key para Anthropic Claude"
                }
            }
        }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.17.2",
    "@google/generative-ai": "^0.24.1",
    "glob": "^8.1.0",
    "minimatch": "^3.1.2",
    "openai": "^4.103.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "@types/glob": "^8.1.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "20.x",
    "@types/vscode": "^1.100.0",
    "@typescript-eslint/eslint-plugin": "^8.31.1",
    "@typescript-eslint/parser": "^8.31.1",
    "@vscode/test-cli": "^0.0.10",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^9.25.1",
    "typescript": "^5.8.3"
  }
}
